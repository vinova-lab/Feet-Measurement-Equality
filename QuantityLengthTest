import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

public class QuantityLengthTest {

    @Test
    void testEquality_YardToYard_SameValue() {
        assertTrue(new QuantityLength(1, LengthUnit.YARDS)
                .equals(new QuantityLength(1, LengthUnit.YARDS)));
    }

    @Test
    void testEquality_YardToYard_DifferentValue() {
        assertFalse(new QuantityLength(1, LengthUnit.YARDS)
                .equals(new QuantityLength(2, LengthUnit.YARDS)));
    }

    @Test
    void testEquality_YardToFeet() {
        assertTrue(new QuantityLength(1, LengthUnit.YARDS)
                .equals(new QuantityLength(3, LengthUnit.FEET)));
    }

    @Test
    void testEquality_FeetToYard() {
        assertTrue(new QuantityLength(3, LengthUnit.FEET)
                .equals(new QuantityLength(1, LengthUnit.YARDS)));
    }

    @Test
    void testEquality_YardToInches() {
        assertTrue(new QuantityLength(1, LengthUnit.YARDS)
                .equals(new QuantityLength(36, LengthUnit.INCHES)));
    }

    @Test
    void testEquality_CmToCm() {
        assertTrue(new QuantityLength(2, LengthUnit.CENTIMETERS)
                .equals(new QuantityLength(2, LengthUnit.CENTIMETERS)));
    }

    @Test
    void testEquality_CmToInches() {
        assertTrue(new QuantityLength(1, LengthUnit.CENTIMETERS)
                .equals(new QuantityLength(0.393701, LengthUnit.INCHES)));
    }

    @Test
    void testNotEqual_CmToFeet() {
        assertFalse(new QuantityLength(1, LengthUnit.CENTIMETERS)
                .equals(new QuantityLength(1, LengthUnit.FEET)));
    }

    @Test
    void testTransitiveProperty() {
        QuantityLength a = new QuantityLength(1, LengthUnit.YARDS);
        QuantityLength b = new QuantityLength(3, LengthUnit.FEET);
        QuantityLength c = new QuantityLength(36, LengthUnit.INCHES);

        assertTrue(a.equals(b));
        assertTrue(b.equals(c));
        assertTrue(a.equals(c));
    }

    @Test
    void testSameReference() {
        QuantityLength q = new QuantityLength(1, LengthUnit.YARDS);
        assertTrue(q.equals(q));
    }

    @Test
    void testNullComparison() {
        QuantityLength q = new QuantityLength(1, LengthUnit.YARDS);
        assertFalse(q.equals(null));
    }

    @Test
    void testNullUnit() {
        assertThrows(IllegalArgumentException.class, () -> {
            new QuantityLength(1, null);
        });
    }
}
